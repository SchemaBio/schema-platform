# ============================================================
# Schema Platform 环境配置
# ============================================================
# 使用: cp .env.example .env 然后编辑标记 🔴 的项

# ── 🔴 必须修改 ─────────────────────────────────────────────

POSTGRES_PASSWORD=change-me-here
JWT_SECRET=change-me-to-a-random-string
CORS_ALLOWED_ORIGINS=http://YOUR_IP:3001,http://YOUR_IP:3002

# ── Sepiida 密钥 ───────────────────────────────────────────
# 🔴 必须与 /opt/schema/sepiida-keys/*.txt 中的值一致
SEPIIDA_AGENT_KEY=agent-dev-key
SEPIIDA_QUERY_KEY=query-dev-key

# ── 数据目录 ───────────────────────────────────────────────
# 🔴 如果没有挂载独立数据盘，可以不修改
OUTPUT_DIR=/mnt/data/output
ARCHIVE_DIR=/mnt/data/archive
TEMPLATE_DIR=/mnt/data/templates

# ── 可选 ───────────────────────────────────────────────────

# 数据库
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=schema_platform
POSTGRES_USER=postgres

# 端口
GERMLINE_WEB_PORT=3001
SOMATIC_WEB_PORT=3002

# Octopus
GIN_MODE=release
JWT_EXPIRE=24h
JWT_REFRESH=168h
DEFAULT_EXECUTOR=local

# AI (可选, 不填则禁用)
SCHEMA_AI_ENABLED=false
SCHEMA_AI_API_URL=https://api.openai.com/v1
SCHEMA_AI_API_KEY=
SCHEMA_AI_MODEL=gpt-4o

# 高级选项
POSTGRES_DATA_DIR=./data/postgres
TZ=Asia/Shanghai
JWT_COOKIE_SECURE=false
CLIENT_PASSWORD_HASH_ENABLED=false
